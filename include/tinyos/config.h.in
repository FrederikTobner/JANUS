/**
 * @file config.h
 * @brief TinyOS build configuration (generated from config.h.in by CMake)
 * 
 * This file is automatically generated during the build process.
 * DO NOT EDIT THIS FILE DIRECTLY - edit config.h.in instead.
 */

#ifndef TINYOS_CONFIG_H
#define TINYOS_CONFIG_H

/*
 * Project Information
 */
#define TINYOS_PROJECT_NAME     "@PROJECT_NAME@"
#define TINYOS_VERSION_MAJOR    @PROJECT_VERSION_MAJOR@
#define TINYOS_VERSION_MINOR    @PROJECT_VERSION_MINOR@
#define TINYOS_VERSION_PATCH    @PROJECT_VERSION_PATCH@
#define TINYOS_VERSION_STRING   "@PROJECT_VERSION@"

/*
 * Build Information
 */
#define TINYOS_BUILD_TYPE       "@CMAKE_BUILD_TYPE@"
#define TINYOS_C_COMPILER       "@CMAKE_C_COMPILER_ID@"
#define TINYOS_C_COMPILER_VERSION "@CMAKE_C_COMPILER_VERSION@"

/*
 * Target Architecture
 */
#define TINYOS_ARCH_X86_64      1
#define TINYOS_TARGET_ARCH      "x86_64"

/*
 * Build Timestamp
 */
#define TINYOS_BUILD_DATE       "@TINYOS_BUILD_DATE@"
#define TINYOS_BUILD_TIME       "@TINYOS_BUILD_TIME@"

/*
 * Feature Flags (configured by CMake options)
 */
#cmakedefine BUILD_TESTS
#cmakedefine ENABLE_DEBUG_OUTPUT
#cmakedefine ENABLE_SERIAL_OUTPUT
#cmakedefine ENABLE_VGA_OUTPUT

/*
 * Memory Configuration
 */
#define TINYOS_PAGE_SIZE        4096
#define TINYOS_KERNEL_VIRT_BASE 0xFFFFFFFF80000000UL

/*
 * Compiler Detection
 */
#if defined(__clang__)
    #define TINYOS_COMPILER_CLANG 1
    #define TINYOS_COMPILER_NAME "Clang"
#elif defined(__GNUC__)
    #define TINYOS_COMPILER_GCC 1
    #define TINYOS_COMPILER_NAME "GCC"
#else
    #define TINYOS_COMPILER_UNKNOWN 1
    #define TINYOS_COMPILER_NAME "Unknown"
#endif

/*
 * Debug Build Detection
 */
#ifdef DEBUG
    #define TINYOS_DEBUG_BUILD 1
#else
    #define TINYOS_DEBUG_BUILD 0
#endif

/*
 * Version Macros
 */
#define TINYOS_VERSION_ENCODE(major, minor, patch) \
    (((major) * 10000) + ((minor) * 100) + (patch))

#define TINYOS_VERSION_CODE \
    TINYOS_VERSION_ENCODE(TINYOS_VERSION_MAJOR, TINYOS_VERSION_MINOR, TINYOS_VERSION_PATCH)

/*
 * Version String Builder
 */
#define TINYOS_STRINGIFY(x) #x
#define TINYOS_TOSTRING(x) TINYOS_STRINGIFY(x)

#define TINYOS_FULL_VERSION_STRING \
    TINYOS_PROJECT_NAME " " TINYOS_VERSION_STRING \
    " (" TINYOS_BUILD_TYPE " build, " TINYOS_COMPILER_NAME ")"

#endif /* TINYOS_CONFIG_H */

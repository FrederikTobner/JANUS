# clangd configuration for TinyOS kernel development
# This file tells clangd (LSP) how to understand our freestanding kernel code

CompileFlags:
  Add:
    # Force C language mode (not Objective-C)
    - "-xc"
    
    # Kernel-specific compiler flags
    - "--target=x86_64-elf"
    - "-ffreestanding"
    - "-nostdlib"
    - "-fno-builtin"
    - "-std=c17"
    
    # Include directories for all modules (relative to project root)
    - "-Ikernel/include"
    - "-Ikernel/lib/memory/include"
    - "-Ikernel/lib/buffer/include"
    - "-Ikernel/lib/fio/include"
    - "-Ikernel/core/include"
    - "-Ikernel/arch/include"
    - "-Ikernel/boot/include"
    - "-Ikernel/mm/include"
    - "-Ikernel/drivers/include"
 
  Remove:
    # Remove flags that confuse clangd analysis
    - "-mno-red-zone"
    - "-fno-stack-protector"
    - "-march=*"
    - "-mtune=*"

Diagnostics:
  UnusedIncludes: Strict

Index:
  Background: Build
  StandardLibrary: No

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  Designators: Yes

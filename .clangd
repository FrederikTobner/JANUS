# clangd configuration for JANUS kernel development

## This file tells clangd (LSP) how to analyze the JANUS kernel source code properly

CompileFlags:
  Add:
    # Force C language mode (not Objective-C)
    - "-xc"

    # Kernel-specific compiler flags
    - "--target=x86_64-elf"
    - "-ffreestanding"
    - "-nostdlib"
    - "-fno-builtin"
    - "-std=c17"

  Remove:
    # Remove flags that confuse clangd analysis
    - "-mno-red-zone"
    - "-fno-stack-protector"
    - "-march=*"
    - "-mtune=*"

Diagnostics:
  UnusedIncludes: Strict

Index:
  Background: Build
  StandardLibrary: No

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  Designators: Yes

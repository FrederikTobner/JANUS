# Limine bootloader configuration for JANUS
# Generated by CMake - do not edit directly
# Format: Limine v8+
#
# Uses Limine native protocol (higher-half kernel).
# This is portable to both x86_64 and AArch64.

timeout: 5

/JANUS (Limine)
    protocol: limine
    kernel_path: boot():/boot/kernel.elf
